          "children": [
            {
              "type": "frame",
              "id": "s6Y9Z",
              "name": "q1",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "p6iE5",
                  "fill": "$--foreground",
                  "content": "What is a will?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "r6Nde",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "A will is a legal document that says who should receive your assets and who should carry out your wishes after you pass away. It reduces confusion and delays.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "cH1vR",
              "name": "q2",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "XHxSe",
                  "fill": "$--foreground",
                  "content": "Who needs a will?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "vIuCj",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Anyone who owns property or has dependants in Kenya. A will helps reduce delays and disputes for your family.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "Bb0QJ",
              "name": "q3",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "oWMv8",
                  "fill": "$--foreground",
                  "content": "What makes a will valid in Kenya?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "puLxf",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "You must be an adult of sound mind, sign the will, and have two independent witnesses sign in your presence. A beneficiary cannot be a witness.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "sx4vD",
              "name": "q4",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "LZiZF",
                  "fill": "$--foreground",
                  "content": "What is an executor?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "zFcdo",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "An executor is responsible for carrying out your instructions, paying debts, and distributing assets. They have a legal duty to act in the best interests of beneficiaries.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "SWsDE",
              "name": "q5",
