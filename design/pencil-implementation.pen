                  "fill": "$--foreground",
                  "content": "What is a beneficiary?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "rHkvU",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "A beneficiary is anyone you want to receive something from your estate — for example a spouse, child, relative, or friend.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "8p1Ih",
              "name": "q6",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "E2Wbc",
                  "fill": "$--foreground",
                  "content": "What is a dependent?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "WqceH",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "A dependant is someone who relies on you financially, such as a child or elderly parent. This can affect how you provide for them.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "vkpqh",
              "name": "q7",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "yuPIT",
                  "fill": "$--foreground",
                  "content": "What is a codicil?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "g3vIR",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "A codicil is a formal amendment to an existing will. It changes specific clauses without rewriting the entire document.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "sdsxW",
              "name": "q8",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "IwSWI",
                  "fill": "$--foreground",
                  "content": "Can I include assets outside Kenya?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "VfiMs",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Yes, but those assets may also be subject to the laws of that country. We recommend seeking local advice for those jurisdictions.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "c8tvc",
              "name": "q9",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "RzE2I",
                  "fill": "$--foreground",
                  "content": "Can I change my will later?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "kh1D2",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Yes. You can draft a new will that replaces the old one, or create a codicil for smaller updates.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "C6BZc",
              "name": "q10",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "wyvmN",
                  "fill": "$--foreground",
                  "content": "Can a beneficiary be a witness?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "IwzAW",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "No. If a beneficiary signs as a witness, their entitlement may be affected or lost. Always choose independent witnesses.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "5wM9l",
              "name": "q11",
              "width": "fill_container",
              "fill": "$--card",
              "cornerRadius": "$--radius-m",
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$--border"
              },
              "layout": "vertical",
              "gap": 6,
              "padding": 16,
              "children": [
                {
                  "type": "text",
                  "id": "45Vvq",
                  "fill": "$--foreground",
                  "content": "Does AI replace legal advice?",
                  "fontFamily": "$--font-secondary",
                  "fontSize": 14,
                  "fontWeight": "600"
                },
                {
                  "type": "text",
                  "id": "Xj7b1",
                  "fill": "$--muted-foreground",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "No. AI helps organize your wishes and explain steps, but legal validity still depends on proper signing and witnesses. For complex estates, request advocate review.",
                  "lineHeight": 1.6,
                  "fontFamily": "$--font-secondary",
                  "fontSize": 13,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
