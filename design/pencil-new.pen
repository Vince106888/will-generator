                  "x": 24,
                  "y": 24
                },
                "TXIO8": {
                  "content": "1. Print the will"
                },
                "S5Ewl": {
                  "content": "Signatures must be on a physical copy.",
                  "y": 30
                },
                "V1VuY": {
                  "type": "frame",
                  "id": "GxzqZ",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
                    {
                      "type": "text",
                      "id": "NdZnj",
                      "fill": "$--muted-foreground",
                      "content": "• Use a clean, readable printout",
                      "fontFamily": "$--font-secondary",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "BIObA",
                      "fill": "$--muted-foreground",
                      "content": "• Keep all pages together",
                      "fontFamily": "$--font-secondary",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                }
              }
            },
            {
              "id": "mxjAQ",
              "type": "ref",
