            {
              "type": "text",
              "id": "lxEG4",
              "fill": "$--foreground",
              "content": "Signing instructions",
              "fontFamily": "$--font-primary",
              "fontSize": 34,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "Jxifv",
              "fill": "$--muted-foreground",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Your will becomes legally effective only after proper signing and witnessing. Follow these steps carefully.",
              "lineHeight": 1.6,
              "fontFamily": "$--font-secondary",
              "fontSize": 16,
              "fontWeight": "normal"
            }
