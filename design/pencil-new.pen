        {
          "type": "frame",
          "id": "xVE1w",
          "name": "Kenyan Validity",
          "width": "fill_container",
          "layout": "vertical",
          "gap": 16,
          "children": [
            {
              "type": "text",
              "id": "WtKbX",
              "fill": "$--foreground",
              "content": "Why Kenyan validity matters",
              "fontFamily": "$--font-primary",
              "fontSize": 32,
              "fontWeight": "600"
            },
            {
              "type": "text",
              "id": "Ji0kI",
              "fill": "$--muted-foreground",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "A will only protects your family if it is written and signed correctly for the laws that apply to your assets. We guide you through Kenya’s requirements in plain English so you understand every decision.",
              "lineHeight": 1.6,
              "fontFamily": "$--font-secondary",
              "fontSize": 15,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "vvhOt",
              "name": "validRow",
              "width": "fill_container",
              "gap": 20,
              "children": [
                {
                  "type": "frame",
                  "id": "HACnw",
                  "name": "validText",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 10,
                  "children": [
                    {
                      "type": "text",
                      "id": "gEvoy",
                      "fill": "$--muted-foreground",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "If you have assets outside Kenya, you can still include them. Their treatment may be subject to the laws of that country, and you may want specific advice for those jurisdictions.",
