                  "width": "fill_container",
                  "height": "fit_content",
                  "x": 24,
                  "y": 24
                },
                "TXIO8": {
                  "content": "2. Gather two witnesses"
                },
                "S5Ewl": {
                  "content": "Witnesses must be independent adults.",
                  "y": 30
                },
                "V1VuY": {
                  "type": "frame",
                  "id": "uBXrD",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
                    {
                      "type": "text",
                      "id": "Ia3a3",
                      "fill": "$--color-warning",
                      "content": "• A beneficiary cannot be a witness",
                      "fontFamily": "$--font-secondary",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "weX6N",
                      "fill": "$--muted-foreground",
                      "content": "• Witnesses should see you sign",
                      "fontFamily": "$--font-secondary",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "iDI5i",
                      "fill": "$--muted-foreground",
                      "content": "• They must sign in your presence",
                      "fontFamily": "$--font-secondary",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                }
              }
            },
            {
              "id": "dCqbV",
