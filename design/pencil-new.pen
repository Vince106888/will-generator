                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "O2qnl",
                      "fill": "$--muted-foreground",
                      "content": "• Witnesses sign immediately after",
                      "fontFamily": "$--font-secondary",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                }
              }
            },
            {
              "id": "F6Evr",
