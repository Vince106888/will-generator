                      "fill": "$--muted-foreground",
                      "content": "• Use your full legal signature",
                      "fontFamily": "$--font-secondary",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "3iGIo",
                      "fill": "$--muted-foreground",
                      "content": "• Record the location (town/county)",
