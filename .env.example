# file: .env.example
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/esheria_wills"
API_PORT=4000
OUTPUT_DIR="./storage"
WEB_BASE_URL="http://localhost:5173"
# Web (Vite build-time)
VITE_API_BASE_URL="http://localhost:4000"

# AI assist (required in production; bounded assist only)
AI_ASSIST_ENABLED=true
AI_ALLOW_LOCAL_STUB=false
AI_CONFIDENCE_THRESHOLD=0.6
AI_PROVIDER=azure
AZURE_MODEL_CONFIG='{"endpoint":"https://your-resource.openai.azure.com","deployment":"your-deployment","apiVersion":"2025-04-01-preview","apiKey":"replace_with_key","model":"optional-model-label","responseFormat":"json_object"}'
# Explicit-only dev/test provider (never for production):
# AI_PROVIDER=local_stub (requires AI_ALLOW_LOCAL_STUB=true)

# Email (resume link delivery) - placeholders until provider is configured
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="change-me"
SMTP_PASS="change-me"
SMTP_SECURE=false
EMAIL_FROM="no-reply@example.com"
EMAIL_FROM_NAME="Esheria Wills"
EMAIL_REPLY_TO="support@example.com"

# Symphony (Elixir) runner
LINEAR_API_KEY="replace_with_linear_api_key"
GITHUB_TOKEN="replace_with_github_token"
SYMPHONY_LINEAR_PROJECT_SLUG=esheria-wills-cf36a69caf55
SYMPHONY_SOURCE_REPO_URL="https://github.com/esherialabs/esheria-wills.git"
SYMPHONY_CODEX_COMMAND="codex app-server"
SYMPHONY_WORKSPACE_ROOT="C:\\symphony-workspaces"
SYMPHONY_RUNTIME_ROOT="C:\\Users\\HP\\work\\esherialabs\\esheria-opssec\\tooling\\symphony\\elixir"
