// file: prisma/schema.prisma
// Prisma schema for Esheria Wills

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WillComplexityLevel {
  LOW
  MEDIUM
  HIGH
}

enum DraftSessionStatus {
  IN_PROGRESS
  READY
  FINALIZED
  ARCHIVED
}

enum DraftSourceMode {
  AI
  STRUCTURED
}

enum AdvocateReviewStatus {
  SUBMITTED
  ACKNOWLEDGED
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum AiInteractionType {
  EXTRACT
  EXPLAIN
  SUMMARIZE
}

enum AiInteractionStatus {
  ACCEPTED
  EDITED
  REJECTED
  ABSTAINED
  FAILED_SCHEMA
}

model WillProfile {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  personal     Json
  family       Json
  assets       Json
  distribution Json
  roles        Json
  instructions Json
  complexity   Json
  validity     Json
  draft        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leads        Lead[]
  analytics    AnalyticsEvent[]
  draftVersions WillDraftVersion[]

  @@index([createdAt])
}

model DraftSession {
  id              String   @id @default(uuid())
  status          DraftSessionStatus @default(IN_PROGRESS)
  sourceMode      DraftSourceMode
  inputSnapshot   Json
  resumeTokenHash String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  versions        WillDraftVersion[]
  advocateReviewRequests AdvocateReviewRequest[]
  aiInteractions AiInteraction[]

  @@index([createdAt])
}

model WillDraftVersion {
  id               String   @id @default(uuid())
  draftSessionId   String
  draftSession     DraftSession @relation(fields: [draftSessionId], references: [id])
  willProfileId    String?
  willProfile      WillProfile? @relation(fields: [willProfileId], references: [id])
  version          Int
  inputSnapshot    Json
  generatedDraft   String
  complexityResult Json
  validityResult   Json
  isCurrent        Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([draftSessionId])
  @@index([willProfileId])
  @@unique([draftSessionId, version])
  advocateReviewRequests AdvocateReviewRequest[]
  aiInteractions AiInteraction[]
}

model AiInteraction {
  id                 String   @id @default(uuid())
  draftSessionId     String
  draftSession       DraftSession @relation(fields: [draftSessionId], references: [id])
  willDraftVersionId String?
  willDraftVersion   WillDraftVersion? @relation(fields: [willDraftVersionId], references: [id])
  interactionType    AiInteractionType
  modelIdentifier    String
  providerIdentifier String
  promptVersion      String
  inputHash          String
  inputPreview       String?
  structuredOutput   Json?
  confidence         Float?
  abstained          Boolean @default(false)
  status             AiInteractionStatus
  userDecision       String?
  createdAt          DateTime @default(now())

  @@index([draftSessionId])
  @@index([willDraftVersionId])
  @@index([interactionType])
  @@index([createdAt])
}

model AdvocateReviewRequest {
  id               String   @id @default(uuid())
  draftSessionId   String
  draftSession     DraftSession @relation(fields: [draftSessionId], references: [id])
  willDraftVersionId String?
  willDraftVersion   WillDraftVersion? @relation(fields: [willDraftVersionId], references: [id])
  status           AdvocateReviewStatus @default(SUBMITTED)
  contactName      String?
  contactEmail     String
  contactPhone     String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([draftSessionId])
  @@index([willDraftVersionId])
}

model Lead {
  id        String   @id @default(uuid())
  email     String
  willId    String?
  will      WillProfile? @relation(fields: [willId], references: [id])
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([email])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wills     WillProfile[]
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  event     String
  payload   Json?
  willId    String?
  will      WillProfile? @relation(fields: [willId], references: [id])
  createdAt DateTime @default(now())

  @@index([event])
  @@index([createdAt])
}
