{
  "name": "esheria-wills",
  "version": "1.0.0",
  "description": "Esheria Wills monorepo",
  "main": "index.js",
  "scripts": {
    "dev": "pnpm -r --parallel --filter ./apps/* dev",
    "dev:web": "pnpm -C apps/web dev",
    "dev:all": "pnpm -r --parallel --filter ./apps/* dev",
    "lint": "pnpm -C apps/api lint && pnpm -C apps/web lint",
    "test": "pnpm -C apps/api test && pnpm -C apps/web test",
    "build": "pnpm -C apps/api build && pnpm -C apps/web build",
    "validate": "pnpm -C apps/api db:generate && pnpm -C apps/api db:migrate && pnpm lint && pnpm test && pnpm build",
    "start": "pnpm -C apps/api start",
    "symphony:readiness": "node scripts/symphony-readiness.mjs",
    "symphony:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-symphony.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "prisma": "5.22.0"
  },
  "dependencies": {
    "@prisma/client": "5.22.0"
  }
}
